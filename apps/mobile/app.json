{
  "expo": {
    "name": "Lifty",
    "slug": "lifty-app",
    "version": "1.0.0",
    "scheme": "lifty",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifty.conductor",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D2B45"
      },
      "package": "com.lifty.conductor",
      "versionCode": 1,
      "usesCleartextTraffic": true
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "mode": "development"
        }
      ],
      "expo-router",
      "expo-web-browser"
    ]
  }
}
