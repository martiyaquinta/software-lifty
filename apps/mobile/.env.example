# Supabase — copy from Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Backend API — optional. Auto-resolved via expo-constants in dev.
# Set only for a fixed host/port:
# EXPO_PUBLIC_API_URL=https://api.lifty.app/api
EXPO_PUBLIC_API_PORT=3000
