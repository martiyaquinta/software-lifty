# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL - Supabase, Railway, Fly.io, etc.)
DATABASE_URL=postgresql://user:password@host:5432/lifty?sslmode=require

# Redis (required for rate limiting, OTP, location cache)
REDIS_URL=redis://:your-redis-password@redis-host:6379

# JWT — generate with: bun run generate-secrets
JWT_SECRET=generate-a-strong-random-secret-here
JWT_REFRESH_SECRET=generate-another-strong-secret-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Rate limiting (per-IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS — comma-separated origins or * for all
CORS_ORIGIN=https://lifty.app,https://app.lifty.app

# Logging
LOG_LEVEL=info
# bcrypt cost factor (higher = more secure but slower)
BCRYPT_COST=12

# Twilio (SMS) — deprecated, replaced by email
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Lifty <noreply@lifty.app>

# DIDIT (KYC identity verification)
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=

# Mercado Pago (payments + withdrawals)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Geo (Photon for geocoding, OSRM for routing — self-host recommended for production)
PHOTON_URL=https://photon.komoot.io
OSRM_URL=https://router.project-osrm.org

# Firebase Cloud Messaging (push notifications)
FCM_SERVICE_ACCOUNT_JSON=

# Supabase Storage (driver documents)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis password (for docker-compose.prod.yml with self-hosted Redis)
REDIS_PASSWORD=

# Database password (for docker-compose.prod.yml with self-hosted Postgres profile)
DB_PASSWORD=

# Backup directory (for scripts/backup.ts)
BACKUP_DIR=./backups
