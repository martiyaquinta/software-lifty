PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://lifty:lifty@localhost:5432/lifty
REDIS_URL=redis://localhost:6379
# Supabase: publishable key for auth (sb_publishable_...), secret key for storage/admin (sb_secret_...)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
PHOTON_URL=https://photon.komoot.io
OSRM_URL=https://router.project-osrm.org
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
# DIDIT verification API base (v3). See https://docs.didit.me
DIDIT_API_URL=https://verification.didit.me/v3
# Published workflow UUID from the DIDIT console (Workflows). KYC type.
DIDIT_WORKFLOW_ID=
# URL DIDIT redirects to when the hosted flow finishes (mobile detects this).
DIDIT_CALLBACK_URL=https://liftyviajes.com/kyc/callback
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
FCM_SERVICE_ACCOUNT_JSON=
# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Lifty <noreply@liftyviajes.com>
# Force email sending in development (set to 'true' to send real emails in dev)
SEND_EMAILS_IN_DEV=
# Admin approval email recipient (comma-separated for multiple)
ADMIN_EMAIL=liftyviajes@gmail.com
