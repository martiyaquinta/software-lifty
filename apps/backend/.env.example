PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://lifty:lifty@localhost:5432/lifty
REDIS_URL=redis://localhost:6379
# JWT verification: SUPABASE_JWT_SECRET takes priority, JWT_SECRET is fallback (backward compat)
SUPABASE_JWT_SECRET=
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
PHOTON_URL=https://photon.komoot.io
OSRM_URL=https://router.project-osrm.org
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
# DIDIT verification API base (v3). See https://docs.didit.me
DIDIT_API_URL=https://verification.didit.me/v3
# Published workflow UUID from the DIDIT console (Workflows). KYC type.
DIDIT_WORKFLOW_ID=
# URL DIDIT redirects to when the hosted flow finishes (mobile detects this).
DIDIT_CALLBACK_URL=https://lifty.app/kyc/callback
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
FCM_SERVICE_ACCOUNT_JSON=
# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Lifty <noreply@lifty.app>
# Twilio (SMS) — deprecated, replaced by email
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
