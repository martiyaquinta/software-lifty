# Dev quickstart: you don't need this file — `bun run setup` (repo root)
# generates apps/backend/.env with everything dev needs. This file documents
# every variable the backend reads.

# Required in production only. In dev the backend defaults to the
# docker-compose.dev.yml Postgres: postgresql://lifty:lifty@localhost:5433/lifty
# WARNING: never point DATABASE_URL at a DB you care about and run tests —
# tests truncate every table. Tests use TEST_DATABASE_URL (default
# postgresql://lifty:lifty@localhost:5433/lifty_test).
# DATABASE_URL=

JWT_SECRET=change-me-jwt-secret-at-least-32-chars

# Optional — rate-limit storage falls back to memory without it.
# docker-compose.dev.yml exposes redis on 6380.
# REDIS_URL=redis://localhost:6380

PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
PHOTON_URL=https://photon.komoot.io
OSRM_URL=https://router.project-osrm.org

# Integrations — all optional in dev. Emails are not sent outside production
# (verification/reset codes are printed to the backend log instead).
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
FCM_SERVICE_ACCOUNT_JSON=
RESEND_API_KEY=
EMAIL_FROM=Lifty <noreply@lifty.app>
