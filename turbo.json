{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {},
    "test": {
      "dependsOn": ["typecheck"],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "REDIS_URL",
        "JWT_SECRET",
        "RATE_LIMIT_MAX",
        "RATE_LIMIT_WINDOW_MS"
      ]
    },
    "build": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["test", "build"]
    }
  }
}
